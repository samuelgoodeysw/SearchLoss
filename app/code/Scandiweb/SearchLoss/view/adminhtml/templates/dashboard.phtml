<?php
$summary = $block->getSummary();
$currentPeriod = $block->getCurrentPeriod();
$rankedTerms = $block->getRankedFailedSearchTerms();
$topOpportunity = $rankedTerms[0] ?? null;
$topMoneyActions = [];
$zeroResultRate = 0;

foreach ($rankedTerms as $term) {
    $bucket = (string)($term['fixEffortBucket'] ?? 'Manual review');

    if (!isset($topMoneyActions[$bucket])) {
        $topMoneyActions[$bucket] = [
            'label' => $bucket,
            'terms' => 0,
            'searches' => 0,
            'value' => 0,
        ];
    }

    $topMoneyActions[$bucket]['terms']++;
    $topMoneyActions[$bucket]['searches'] += (int)($term['count'] ?? 0);
    $topMoneyActions[$bucket]['value'] += (float)($term['lostRevenue'] ?? 0);
}

usort($topMoneyActions, function ($a, $b) {
    return $b['value'] <=> $a['value'];
});

$topMoneyActions = array_slice($topMoneyActions, 0, 3);

if (($summary['failed_searches'] ?? 0) > 0 && method_exists($block, 'getSearchData')) {
    $searchData = $block->getSearchData();
    $zeroResultRate = (float)($searchData['zeroResultRate'] ?? 0);
}

function activeStyle($current, $period) {
    return $current === $period
        ? 'background:#eb5202;color:#fff;border-color:#eb5202;'
        : 'background:#fff;color:#1f2937;border-color:#d1d5db;';
}

function priorityStyle($priority) {
    $priority = strtolower((string)$priority);

    if ($priority === 'high') {
        return 'background:#fee2e2;color:#991b1b;border-color:#fecaca;';
    }

    if ($priority === 'medium') {
        return 'background:#fef3c7;color:#92400e;border-color:#fde68a;';
    }

    return 'background:#f1f5f9;color:#334155;border-color:#cbd5e1;';
}

function money($value) {
    return '$' . number_format((float)$value, 0);
}

function tooltipLabel($label, $tooltip) {
    return '<span class="searchloss-tooltip-label">'
        . htmlspecialchars($label, ENT_QUOTES, 'UTF-8')
        . '<span class="searchloss-tooltip-icon" tabindex="0">?</span>'
        . '<span class="searchloss-tooltip-bubble">'
        . htmlspecialchars($tooltip, ENT_QUOTES, 'UTF-8')
        . '</span>'
        . '</span>';
}

function fixEffortTooltip($label) {
    $tooltips = [
        'Quick admin/config fix' => 'These are likely Magento admin setting issues, such as status, visibility, website assignment, category assignment, or stock setup. These may be faster wins because related products already appear to exist.',
        'Attribute/search configuration fix' => 'These searches look like Magento has related products, but search is not matching them well. Review indexing, searchable attributes, search weights, synonyms, and customer wording.',
        'Catalogue data fix' => 'These searches likely need better product data, such as SKU, part number, manufacturer, brand, model, fitment, or other searchable product information.',
        'Synonym/search term fix' => 'These searches may use different wording, spelling, spacing, or punctuation from the catalogue. Add safe synonyms or search terms only where the intent is clear.',
        'Search relevance/ranking review' => 'These searches may need result ordering, ranking, filters, or merchandising review rather than a simple catalogue data change.',
        'Catalogue coverage review' => 'These searches may point to products, categories, or substitutes that are missing, poorly named, or not clearly represented in the catalogue.',
        'Manual review' => 'These searches need human review because the current Magento evidence does not clearly point to one fix type.',
    ];

    return $tooltips[$label] ?? 'This groups failed searches by the likely type of work needed to review or fix them.';
}

function catalogEvidenceTooltip($label) {
    $tooltips = [
        'Search words checked' => 'The key words taken from the customer search and checked against Magento product and category data.',
        'SKU matches' => 'Products with a SKU that matches the customer search. If this is above zero, search may not be finding SKU data correctly.',
        'Full-phrase product matches' => 'Products whose name contains the full search phrase. If this is above zero but search failed, Magento may not be searching the right product data.',
        'Keyword product matches' => 'Products whose name contains one or more key words from the search. This can show related products even when the exact phrase does not exist.',
        'Related product matches' => 'Products or SKUs found in Magento that look related to this failed search. If this is above zero but search failed, review product wording, searchable attributes, synonyms, and indexing.',
        'Enabled product matches' => 'Related products that are enabled in Magento. If enabled products exist but search failed, review search visibility, searchable attributes, synonyms, and indexing.',
        'Disabled product matches' => 'Related products that are disabled in Magento. Customers may be searching for items that exist in the catalogue but are not currently sellable or visible.',
        'Visible in search' => 'Related products set to appear in search or catalogue/search. If this is above zero but search failed, review indexing, search configuration, and searchable attributes.',
        'Not visible in search' => 'Related products that are not set to appear in search. Review these if they should help customers find this term.',
        'Assigned to website' => 'Related products that are assigned to at least one Magento website. If this is zero, the products may exist but not be available on the current storefront.',
        'Not assigned to website' => 'Related products that do not appear to be assigned to a Magento website. Review website assignment if these products should be sellable or searchable.',
        'Assigned to category' => 'Related products that are assigned to at least one category. Category assignment can help customers browse to the right products even when search needs improvement.',
        'Not assigned to category' => 'Related products that do not appear to be assigned to a category. Review category assignment if customers should be able to find these products through navigation.',
        'In stock product matches' => 'Related products that are currently in stock according to Magento stock status.',
        'Out of stock product matches' => 'Related products that are out of stock. If this is above zero, customers may be searching for products that exist but are not currently buyable.',
        'Core product attributes found' => 'Core Magento product fields checked for search configuration, such as name, SKU, description, and short description.',
        'Searchable core product attributes' => 'Core Magento product fields currently configured as searchable.',
        'Core attribute search coverage' => 'How many core product fields are searchable compared with how many were found.',
        'Identity attributes found list' => 'Product identity fields found in this Magento store, such as manufacturer, brand, MPN, model, or part number.',
        'Searchable identity attributes list' => 'Product identity fields currently configured as searchable.',
        'Identity attribute search coverage' => 'How many identity fields are searchable compared with how many were found.',
        'Full-phrase category matches' => 'Categories whose name contains the full search phrase. If this is above zero, the search may need to route customers to that category.',
        'Keyword category matches' => 'Categories whose name contains one or more key words from the search. This can show a related category path for the failed search.',
        'Catalog signal' => 'A quick summary of whether Magento appears to have matching or related catalog data for this failed search.',
        'What this suggests' => 'What the catalog evidence likely means: missing catalog coverage, weak product data, missing synonyms, or search not connecting customer wording to Magento data.',
    ];

    return $tooltips[$label] ?? 'Extra Magento catalog context for this failed search.';
}
